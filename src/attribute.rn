//! Borrowed attribute cursor over a start or empty element's raw attribute slice.
//!
//! Attribute values stay encoded and borrowed. Decoding is handled separately by
//! `EncodedText`, which keeps attribute scanning allocation-free.

use ..{
    Attribute,
    AttributeCursor,
    EncodedText,
    Error,
    Name,
};
use ..bytes.{err, name_end, skip_ws};

impl &AttributeCursor {
    /// Returns the raw attribute-list slice being scanned.
    pub fn source() &[u8] {
        return self.raw;
    }

    /// Returns `true` after the cursor has reached the end of the attribute list.
    pub fn is_done() bool {
        return self.done;
    }
}

impl &mut AttributeCursor {
    /// Parses and returns the next attribute, or `None` at the end of the list.
    pub fn next() ?Attribute!Error {
        if (self.done) {
            return .{ Ok: .None };
        }

        let text = self.raw;
        let mut index = skip_ws(text, self.index);
        if (index >= #text) {
            self.index = index;
            self.done = true;
            return .{ Ok: .None };
        }

        // Attribute names are parsed with the same XML Name rules as element
        // names, so namespace prefixes and non-ASCII names share one path.
        let name_start = index;
        let name_stop = name_end(text, name_start).map_err([](parse_err: Error) Error {
            return .{ kind: parse_err.kind, offset: parse_err.offset };
        }).!;
        index = skip_ws(text, name_stop);
        if (index >= #text or text.[index] != b'=') {
            return .{ Err: err(.InvalidAttribute, self.offset_base + index) };
        }
        index = skip_ws(text, index + 1);
        if (index >= #text or (text.[index] != b'"' and text.[index] != b'\'')) {
            return .{ Err: err(.InvalidAttribute, self.offset_base + index) };
        }

        let quote = text.[index];
        let value_start = index + 1;
        index = value_start;
        // Attribute values are returned encoded; the cursor only has to find
        // the matching quote and leave entity decoding to `EncodedText`.
        while (index < #text and text.[index] != quote) {
            index += 1;
        }
        if (index >= #text) {
            return .{ Err: err(.InvalidAttribute, self.offset_base + value_start) };
        }

        let raw_stop = index + 1;
        self.index = raw_stop;
        return .{ Ok: .{ Some: Attribute.{
            name: Name.{ raw: text.&[name_start .. name_stop] },
            value: EncodedText.{ raw: text.&[value_start .. index] },
            raw: text.&[name_start .. raw_stop],
        } } };
    }
}
