//! Well-formedness validation on top of the pull reader.
//!
//! Validation enforces single-root structure, matching start/end names, XML
//! declaration placement, and duplicate attributes.

use base.coll.{list, map};
use base.mem.alloc.{AllocError, Allocator};

use ..{
    Element,
    Error,
    Event,
    Name,
    Reader,
    ValidateError,
    ValidateErrorKind,
    reader,
};

// Builds a validation error at the source offset that caused it.
fn validate_err(kind: ValidateErrorKind, offset: usize) ValidateError {
    return .{ kind, offset };
}

// Preserves allocation failure shape in the public validation error domain.
fn validate_alloc_err(err: AllocError, offset: usize) ValidateError {
    match (err) {
        .CapacityOverflow => return validate_err(.CapacityOverflow, offset),
        .OutOfMemory => return validate_err(.OutOfMemory, offset),
    }
}

// Preserves tokenizer offsets while moving parse failures into validation.
fn lift_parse(err: Error) ValidateError {
    return .{ kind: .{ Parse: err.kind }, offset: err.offset };
}

// Text outside the root may only contain XML whitespace.
fn is_ignorable_text(raw: &[u8]) bool {
    for (byte: raw.iter()) {
        if (!(byte == b' ' or byte == b'\n' or byte == b'\r' or byte == b'\t')) {
            return false;
        }
    }
    return true;
}

// Tracks attribute names for one element to detect duplicates.
fn has_duplicate_attributes(
    element: Element,
    alloc: &mut Allocator,
    event_start: usize,
) bool!ValidateError {
    let seen = map[&[u8], bool]()..&;
    defer seen.deinit(alloc);
    let mut cursor = element.attributes();
    while (true) {
        let next = cursor..&.next().map_err(lift_parse).?;
        let .{ Some: attr } = next else break;
        if (seen.get_ptr(attr.name.raw).is_some()) {
            return .{ Ok: true };
        }
        match (seen.try_insert(alloc, attr.name.raw, true)) {
            .{ Ok: _ } => {},
            .{ Err: err } => return .{ Err: validate_alloc_err(err, event_start) },
        }
    }
    return .{ Ok: false };
}

impl &mut Reader {
    /// Validates this reader's remaining source as a single-root XML document.
    pub fn validate(alloc: &mut Allocator) void!ValidateError {
        let stack = list[Name]()..&;
        defer stack.deinit(alloc);
        let mut saw_root = false;
        let mut closed_root = false;
        let mut saw_declaration = false;

        while (true) {
            let event_start = self.offset();
            let next = self.next().map_err(lift_parse).?;
            let .{ Some: event } = next else break;
            match (event) {
                .{ Start: element } => {
                    if (has_duplicate_attributes(element, alloc, event_start).?) {
                        return .{ Err: validate_err(.DuplicateAttribute, event_start) };
                    }
                    if (closed_root and !is_ignorable_text(element.raw)) {
                        let offset = self.index - element.raw.@len();
                        return .{ Err: validate_err(.MultipleRoots, offset) };
                    }
                    if (stack.is_empty()) {
                        if (saw_root) {
                            let offset = self.index - element.raw.@len();
                            return .{ Err: validate_err(.MultipleRoots, offset) };
                        }
                        saw_root = true;
                    }
                    let offset = self.index - element.raw.@len();
                    match (stack.try_push(alloc, element.name)) {
                        .{ Ok: _ } => {},
                        .{ Err: err } => return .{ Err: validate_alloc_err(err, offset) },
                    }
                },
                .{ Empty: element } => {
                    if (has_duplicate_attributes(element, alloc, event_start).?) {
                        return .{ Err: validate_err(.DuplicateAttribute, event_start) };
                    }
                    if (stack.is_empty()) {
                        if (saw_root) {
                            let offset = self.index - element.raw.@len();
                            return .{ Err: validate_err(.MultipleRoots, offset) };
                        }
                        saw_root = true;
                        closed_root = true;
                    }
                },
                .{ End: name } => {
                    let .{ Some: open } = stack.pop() else {
                        return .{ Err: validate_err(.MismatchedEnd, self.index) };
                    };
                    if (!open.eq(name.raw)) {
                        return .{ Err: validate_err(.MismatchedEnd, self.index) };
                    }
                    if (stack.is_empty()) {
                        closed_root = true;
                    }
                },
                .{ Text: text } => {
                    if (closed_root and !is_ignorable_text(text.raw)) {
                        let offset = self.index - text.raw.@len();
                        return .{ Err: validate_err(.MultipleRoots, offset) };
                    }
                },
                .{ Declaration: _ } => {
                    let invalid_declaration = event_start > 3
                        or saw_declaration
                        or saw_root
                        or closed_root
                        or !stack.is_empty();
                    if (invalid_declaration) {
                        return .{ Err: validate_err(.{ Parse: .InvalidDeclaration }, event_start) };
                    }
                    saw_declaration = true;
                },
                .{ ProcessingInstruction: _ } => {},
                .{ Comment: _ } => {},
                .{ CData: _ } => {},
                .{ Doctype: _ } => {},
            }
        }

        if (!stack.is_empty()) {
            return .{ Err: validate_err(.UnclosedElement, self.index) };
        }
        if (!saw_root) {
            return .{ Err: validate_err(.MissingRoot, self.index) };
        }
        return .{ Ok: {} };
    }
}

impl &[u8] {
    /// Validates this source as a well-formed single-root XML document.
    pub fn validate(alloc: &mut Allocator) void!ValidateError {
        let mut r = reader(self);
        return r..&.validate(alloc);
    }
}
