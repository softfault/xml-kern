use base.mem.alloc.gpa;
use base.coll.range;
use base.test;
use std.io;
use sys.mem.page;
use xml.{DecodeErrorKind, ErrorKind, Event, ExpectErrorKind, ValidateErrorKind, reader};

fn expect_next(r: &mut xml.Reader) Event {
    let t = test.report(io.stderr())..&;
    return r.next().should_ok().sum(@loc(), t).should_some().sum(@loc(), t);
}

fn expect_prefix_errors(source: &[u8], min_len: usize, complete_events: usize) void {
    let t = test.report(io.stderr())..&;
    for (split: range[usize](min_len, #source)) {
        let mut r = reader(source.&[0 .. split]);
        _ = r..&.next().should_err().sum(@loc(), t);
    }

    let mut complete = reader(source);
    for (_: range[usize](0, complete_events)) {
        _ = complete..&.next().should_ok().sum(@loc(), t).should_some().sum(@loc(), t);
    }
}

fn check_basic_events() void {
    let t = test.report(io.stderr())..&;
    let mut r = reader("<?xml version=\"1.0\"?><root id=\"7\" flag='yes'>hello &amp; <![CDATA[raw <>&]]><!--note--><?go now?><empty a=\"b\"/></root>");

    match (expect_next(r..&)) {
        .{ Declaration: pi } => {
            pi.target.eq("xml").should().sum(@loc(), t);
        },
        _ => t.fail_at(@loc(), "expected XML declaration"),
    }

    match (expect_next(r..&)) {
        .{ Start: root } => {
            root.name.eq("root").should().sum(@loc(), t);
            let mut attrs = root.attributes();
            let id = attrs..&.next().should_ok().sum(@loc(), t).should_some().sum(@loc(), t);
            let flag = attrs..&.next().should_ok().sum(@loc(), t).should_some().sum(@loc(), t);
            id.name.eq("id").should().sum(@loc(), t);
            id.value.raw.should().eq("7").sum(@loc(), t);
            flag.name.eq("flag").should().sum(@loc(), t);
            flag.value.raw.should().eq("yes").sum(@loc(), t);
            attrs..&.next().should_ok().sum(@loc(), t).should_none().sum(@loc(), t);
        },
        _ => t.fail_at(@loc(), "expected root start"),
    }

    match (expect_next(r..&)) {
        .{ Text: text } => {
            text.raw.should().eq("hello &amp; ").sum(@loc(), t);
            text.contains_reference().should().sum(@loc(), t);
        },
        _ => t.fail_at(@loc(), "expected text"),
    }
    match (expect_next(r..&)) {
        .{ CData: text } => text.raw.should().eq("raw <>&").sum(@loc(), t),
        _ => t.fail_at(@loc(), "expected cdata"),
    }
    match (expect_next(r..&)) {
        .{ Comment: text } => text.raw.should().eq("note").sum(@loc(), t),
        _ => t.fail_at(@loc(), "expected comment"),
    }
    match (expect_next(r..&)) {
        .{ ProcessingInstruction: pi } => {
            pi.target.eq("go").should().sum(@loc(), t);
            pi.body.should().eq("now").sum(@loc(), t);
        },
        _ => t.fail_at(@loc(), "expected processing instruction"),
    }
    match (expect_next(r..&)) {
        .{ Empty: empty } => {
            empty.name.eq("empty").should().sum(@loc(), t);
            let mut attrs = empty.attributes();
            let attr = attrs..&.next().should_ok().sum(@loc(), t).should_some().sum(@loc(), t);
            attr.name.eq("a").should().sum(@loc(), t);
            attr.value.raw.should().eq("b").sum(@loc(), t);
        },
        _ => t.fail_at(@loc(), "expected empty element"),
    }
    match (expect_next(r..&)) {
        .{ End: name } => name.eq("root").should().sum(@loc(), t),
        _ => t.fail_at(@loc(), "expected root end"),
    }
    r..&.next().should_ok().sum(@loc(), t).should_none().sum(@loc(), t);
    r.&.is_done().should().sum(@loc(), t);
}

fn check_decode_entities() void {
    let t = test.report(io.stderr())..&;
    let text = xml.EncodedText.{ raw: "a&amp;b&lt;c&gt;&apos;&quot;&#65;&#x1F600;" };
    text.decoded_size().should_ok().sum(@loc(), t).should().eq(13).sum(@loc(), t);

    let mut out = [32]u8.{undef};
    let written = text.write_decoded(out..&[0 .. 32]).should_ok().sum(@loc(), t);
    let expected = [13]u8.{ b'a', b'&', b'b', b'<', b'c', b'>', b'\'', b'"', b'A', 0xF0, 0x9F, 0x98, 0x80 };
    out.&[0 .. written].should().eq(expected.&[0 .. 13]).sum(@loc(), t);

    let page = page()..&;
    let gpa = gpa().on(page)..&;
    let mut cloned = text.clone_decoded(gpa).should_ok().sum(@loc(), t);
    defer cloned..&.deinit(gpa);
    cloned.&.as_str().should().eq(out.&[0 .. written]).sum(@loc(), t);
}

fn check_doctype_and_bom() void {
    let t = test.report(io.stderr())..&;
    let source = [60]u8.{
        0xEF, 0xBB, 0xBF,
        b'<', b'!', b'D', b'O', b'C', b'T', b'Y', b'P', b'E', b' ',
        b'n', b'o', b't', b'e', b' ', b'[', b' ', b'<', b'!', b'E',
        b'N', b'T', b'I', b'T', b'Y', b' ', b'w', b'r', b'i', b't',
        b'e', b'r', b' ', b'"', b'D', b'o', b'n', b'a', b'l', b'd',
        b' ', b'D', b'u', b'c', b'k', b'"', b'>', b' ', b']', b'>',
        b'<', b'n', b'o', b't', b'e', b'/', b'>',
    };
    let mut r = reader(source.&[0 .. 60]);
    match (expect_next(r..&)) {
        .{ Doctype: text } => text.raw.should().eq(" note [ <!ENTITY writer \"Donald Duck\"> ]").sum(@loc(), t),
        _ => t.fail_at(@loc(), "expected doctype"),
    }
    match (expect_next(r..&)) {
        .{ Empty: note } => note.name.eq("note").should().sum(@loc(), t),
        _ => t.fail_at(@loc(), "expected empty note"),
    }
    r..&.next().should_ok().sum(@loc(), t).should_none().sum(@loc(), t);
}

fn check_errors_have_offsets() void {
    let t = test.report(io.stderr())..&;
    let mut full_decl = reader("<?xml version=\"1.0\" encoding=\"utf-8\" standalone=\"yes\"?><root/>");
    match (expect_next(full_decl..&)) {
        .{ Declaration: pi } => {
            pi.target.eq("xml").should().sum(@loc(), t);
            pi.body.should().eq("version=\"1.0\" encoding=\"utf-8\" standalone=\"yes\"").sum(@loc(), t);
        },
        _ => t.fail_at(@loc(), "expected full XML declaration"),
    }

    let mut r = reader("<root><!--oops");
    match (expect_next(r..&)) {
        .{ Start: root } => root.name.eq("root").should().sum(@loc(), t),
        _ => t.fail_at(@loc(), "expected root"),
    }
    let err = r..&.next().should_err().sum(@loc(), t);
    err.kind.should().eq(ErrorKind.UnterminatedComment).sum(@loc(), t);
    err.offset.should().eq(6).sum(@loc(), t);

    let bad = xml.EncodedText.{ raw: "&wat;" }.decoded_size().should_err().sum(@loc(), t);
    bad.kind.should().eq(DecodeErrorKind.UnknownEntity).sum(@loc(), t);
    bad.offset.should().eq(0).sum(@loc(), t);

    let loc = xml.locate("a\nbc", 3);
    loc.line.should().eq(2).sum(@loc(), t);
    loc.column.should().eq(2).sum(@loc(), t);

    let mut bad_comment = reader("<root><!--bad--body--></root>");
    match (expect_next(bad_comment..&)) {
        .{ Start: root } => root.name.eq("root").should().sum(@loc(), t),
        _ => t.fail_at(@loc(), "expected root"),
    }
    let comment_err = bad_comment..&.next().should_err().sum(@loc(), t);
    comment_err.kind.should().eq(ErrorKind.InvalidComment).sum(@loc(), t);
    comment_err.offset.should().eq(13).sum(@loc(), t);

    let mut bad_text = reader("<root>bad ]]></root>");
    match (expect_next(bad_text..&)) {
        .{ Start: root } => root.name.eq("root").should().sum(@loc(), t),
        _ => t.fail_at(@loc(), "expected root"),
    }
    let text_err = bad_text..&.next().should_err().sum(@loc(), t);
    text_err.kind.should().eq(ErrorKind.InvalidCharacterData).sum(@loc(), t);

    let mut late_decl = reader("<root><?xml version=\"1.0\"?></root>");
    match (expect_next(late_decl..&)) {
        .{ Start: root } => root.name.eq("root").should().sum(@loc(), t),
        _ => t.fail_at(@loc(), "expected root"),
    }
    let decl_err = late_decl..&.next().should_err().sum(@loc(), t);
    decl_err.kind.should().eq(ErrorKind.InvalidDeclaration).sum(@loc(), t);

    let mut bad_decl = reader("<?xml encoding=\"utf-8\"?><root/>");
    let bad_decl_err = bad_decl..&.next().should_err().sum(@loc(), t);
    bad_decl_err.kind.should().eq(ErrorKind.InvalidDeclaration).sum(@loc(), t);

    let mut duplicate_decl_attr = reader("<?xml version=\"1.0\" version=\"1.1\"?><root/>");
    let duplicate_decl_attr_err = duplicate_decl_attr..&.next().should_err().sum(@loc(), t);
    duplicate_decl_attr_err.kind.should().eq(ErrorKind.InvalidDeclaration).sum(@loc(), t);

    let mut out_of_order_decl = reader("<?xml version=\"1.0\" standalone=\"yes\" encoding=\"utf-8\"?><root/>");
    let out_of_order_decl_err = out_of_order_decl..&.next().should_err().sum(@loc(), t);
    out_of_order_decl_err.kind.should().eq(ErrorKind.InvalidDeclaration).sum(@loc(), t);

    let mut bad_version_decl = reader("<?xml version=\"2.0\"?><root/>");
    let bad_version_decl_err = bad_version_decl..&.next().should_err().sum(@loc(), t);
    bad_version_decl_err.kind.should().eq(ErrorKind.InvalidDeclaration).sum(@loc(), t);

    let mut bad_encoding_decl = reader("<?xml version=\"1.0\" encoding=\"1bad\"?><root/>");
    let bad_encoding_decl_err = bad_encoding_decl..&.next().should_err().sum(@loc(), t);
    bad_encoding_decl_err.kind.should().eq(ErrorKind.InvalidDeclaration).sum(@loc(), t);

    let mut bad_standalone_decl = reader("<?xml version=\"1.0\" standalone=\"maybe\"?><root/>");
    let bad_standalone_decl_err = bad_standalone_decl..&.next().should_err().sum(@loc(), t);
    bad_standalone_decl_err.kind.should().eq(ErrorKind.InvalidDeclaration).sum(@loc(), t);

    let mut invalid_name = reader("<1root/>");
    let invalid_name_err = invalid_name..&.next().should_err().sum(@loc(), t);
    invalid_name_err.kind.should().eq(ErrorKind.InvalidName).sum(@loc(), t);

    let invalid_utf8_source = [3]u8.{ b'<', 0xC0, b'>' };
    let mut invalid_utf8 = reader(invalid_utf8_source.&[0 .. 3]);
    let invalid_utf8_err = invalid_utf8..&.next().should_err().sum(@loc(), t);
    invalid_utf8_err.kind.should().eq(ErrorKind.InvalidName).sum(@loc(), t);

    let mut unicode_name = reader("<é/>");
    match (expect_next(unicode_name..&)) {
        .{ Empty: element } => element.name.raw.should().eq("é").sum(@loc(), t),
        _ => t.fail_at(@loc(), "expected unicode empty element"),
    }
}

fn check_validation() void {
    let t = test.report(io.stderr())..&;
    let page = page()..&;
    let gpa = gpa().on(page)..&;

    xml.validate("<root><child/><child>text</child></root>", gpa).should_ok().sum(@loc(), t);

    let mismatch = xml.validate("<root><a></root>", gpa).should_err().sum(@loc(), t);
    match (mismatch.kind) {
        .MismatchedEnd => {},
        _ => t.fail_at(@loc(), "expected mismatched end"),
    }

    let multiple = xml.validate("<a/><b/>", gpa).should_err().sum(@loc(), t);
    match (multiple.kind) {
        .MultipleRoots => {},
        _ => t.fail_at(@loc(), "expected multiple roots"),
    }

    let missing = xml.validate("   <!-- only comment -->", gpa).should_err().sum(@loc(), t);
    match (missing.kind) {
        .MissingRoot => {},
        _ => t.fail_at(@loc(), "expected missing root"),
    }

    let parse = xml.validate("<root><!-- bad", gpa).should_err().sum(@loc(), t);
    match (parse.kind) {
        .{ Parse: kind } => kind.should().eq(ErrorKind.UnterminatedComment).sum(@loc(), t),
        _ => t.fail_at(@loc(), "expected parse error"),
    }

    let duplicate = xml.validate("<root a=\"1\" a=\"2\"/>", gpa).should_err().sum(@loc(), t);
    match (duplicate.kind) {
        .DuplicateAttribute => {},
        _ => t.fail_at(@loc(), "expected duplicate attribute"),
    }

    let nested_duplicate = xml.validate("<root><child id=\"1\" id=\"2\"/></root>", gpa).should_err().sum(@loc(), t);
    match (nested_duplicate.kind) {
        .DuplicateAttribute => {},
        _ => t.fail_at(@loc(), "expected nested duplicate attribute"),
    }

    let many_attrs = xml.validate("<root a0=\"0\" a1=\"1\" a2=\"2\" a3=\"3\" a4=\"4\" a5=\"5\" a6=\"6\" a7=\"7\" a8=\"8\" a9=\"9\" a10=\"10\" a11=\"11\" a12=\"12\" a13=\"13\" a14=\"14\" a7=\"dup\"/>", gpa).should_err().sum(@loc(), t);
    match (many_attrs.kind) {
        .DuplicateAttribute => {},
        _ => t.fail_at(@loc(), "expected duplicate among many attributes"),
    }
}

fn check_expect_combinators() void {
    let t = test.report(io.stderr())..&;
    let mut r = reader("<!--meta--><root><leaf/></root>");
    let root = r..&.expect_start("root").should_ok().sum(@loc(), t);
    root.name.eq("root").should().sum(@loc(), t);
    let leaf = r..&.expect_empty("leaf").should_ok().sum(@loc(), t);
    leaf.name.eq("leaf").should().sum(@loc(), t);
    r..&.expect_end("root").should_ok().sum(@loc(), t).eq("root").should().sum(@loc(), t);
    r..&.next_significant().should_ok().sum(@loc(), t).should_none().sum(@loc(), t);

    let mut wrong = reader("<root/>");
    let err = wrong..&.expect_start("root").should_err().sum(@loc(), t);
    match (err.kind) {
        .UnexpectedEvent => {},
        _ => t.fail_at(@loc(), "expected unexpected event"),
    }

    let mut mismatch = reader("<other></other>");
    let mismatch_err = mismatch..&.expect_start("root").should_err().sum(@loc(), t);
    match (mismatch_err.kind) {
        .NameMismatch => {},
        _ => t.fail_at(@loc(), "expected name mismatch"),
    }
}

fn check_stream_combinators() void {
    let t = test.report(io.stderr())..&;

    let mut counted_reader = reader("<root><child/>text</root>");
    let mut stats = xml.SinkStats.{};
    let stream = &mut xml.EventStream.{ counted_reader..& };
    let sink = &mut xml.EventSink.{ stats..& };
    xml.drain_events(stream, sink).should_ok().sum(@loc(), t).should().eq(4).sum(@loc(), t);
    stats.events.should().eq(4).sum(@loc(), t);
    stats.starts.should().eq(1).sum(@loc(), t);
    stats.empties.should().eq(1).sum(@loc(), t);
    stats.ends.should().eq(1).sum(@loc(), t);
    stats.text.should().eq(1).sum(@loc(), t);

    let mut noisy = reader("<!--meta--> \n <root><?go?></root>");
    let mut significant = noisy..&.filter_significant();
    match (significant..&.next().should_ok().sum(@loc(), t).should_some().sum(@loc(), t)) {
        .{ Start: root } => root.name.eq("root").should().sum(@loc(), t),
        _ => t.fail_at(@loc(), "expected significant start"),
    }
    match (significant..&.next().should_ok().sum(@loc(), t).should_some().sum(@loc(), t)) {
        .{ End: name } => name.eq("root").should().sum(@loc(), t),
        _ => t.fail_at(@loc(), "expected significant end"),
    }
    significant..&.next().should_ok().sum(@loc(), t).should_none().sum(@loc(), t);

    let mut source = reader("<root><leaf/>tail</root>");
    let mut elements = source..&.elements();
    elements..&.next().should_ok().sum(@loc(), t).should_some().sum(@loc(), t).name.eq("root").should().sum(@loc(), t);
    elements..&.next().should_ok().sum(@loc(), t).should_some().sum(@loc(), t).name.eq("leaf").should().sum(@loc(), t);
    elements..&.next().should_ok().sum(@loc(), t).should_none().sum(@loc(), t);

    let mut named_source = reader("<root><leaf/></root>");
    let mut names = named_source..&.names();
    names..&.next().should_ok().sum(@loc(), t).should_some().sum(@loc(), t).eq("root").should().sum(@loc(), t);
    names..&.next().should_ok().sum(@loc(), t).should_some().sum(@loc(), t).eq("leaf").should().sum(@loc(), t);
    names..&.next().should_ok().sum(@loc(), t).should_some().sum(@loc(), t).eq("root").should().sum(@loc(), t);
    names..&.next().should_ok().sum(@loc(), t).should_none().sum(@loc(), t);
}

fn check_namespace_views() void {
    let t = test.report(io.stderr())..&;
    let mut r = reader("<x:root xmlns=\"urn:default\" xmlns:x=\"urn:x\" x:id=\"7\" plain=\"v\"/>");
    match (expect_next(r..&)) {
        .{ Empty: root } => {
            let root_name = root.&.qualified_name();
            root_name.prefix.should_some().sum(@loc(), t).should().eq("x").sum(@loc(), t);
            root_name.local.should().eq("root").sum(@loc(), t);

            let mut attrs = root.attributes();
            let default_ns = attrs..&.next().should_ok().sum(@loc(), t).should_some().sum(@loc(), t);
            match (default_ns.&.namespace_declaration().should_some().sum(@loc(), t)) {
                .{ Default: uri } => uri.raw.should().eq("urn:default").sum(@loc(), t),
                _ => t.fail_at(@loc(), "expected default namespace"),
            }

            let prefixed_ns = attrs..&.next().should_ok().sum(@loc(), t).should_some().sum(@loc(), t);
            match (prefixed_ns.&.namespace_declaration().should_some().sum(@loc(), t)) {
                .{ Prefixed: binding } => {
                    binding.prefix.should().eq("x").sum(@loc(), t);
                    binding.uri.raw.should().eq("urn:x").sum(@loc(), t);
                },
                _ => t.fail_at(@loc(), "expected prefixed namespace"),
            }

            let id = attrs..&.next().should_ok().sum(@loc(), t).should_some().sum(@loc(), t);
            (!id.&.is_namespace_declaration()).should().sum(@loc(), t);
            let id_name = id.&.qualified_name();
            id_name.prefix.should_some().sum(@loc(), t).should().eq("x").sum(@loc(), t);
            id_name.local.should().eq("id").sum(@loc(), t);

            let plain = attrs..&.next().should_ok().sum(@loc(), t).should_some().sum(@loc(), t);
            plain.&.qualified_name().prefix.should_none().sum(@loc(), t);
            plain.name.&.local().should().eq("plain").sum(@loc(), t);
        },
        _ => t.fail_at(@loc(), "expected namespaced empty element"),
    }
}

fn check_borrowed_index() void {
    let t = test.report(io.stderr())..&;
    let page = page()..&;
    let gpa = gpa().on(page)..&;
    let index = xml.build_index("<root><item id=\"a\"><leaf/></item><item id=\"b\"/><other/></root>", gpa).should_ok().sum(@loc(), t)..&;
    defer index.deinit(gpa);

    index.len().should().eq(5).sum(@loc(), t);
    let root_id = index.root().should_some().sum(@loc(), t);
    let root = index.get(root_id).should_some().sum(@loc(), t);
    root.element.name.eq("root").should().sum(@loc(), t);
    root.depth.should().eq(0).sum(@loc(), t);

    let first_item_id = index.first_child_named(root_id, "item").should_some().sum(@loc(), t);
    let first_item = index.get(first_item_id).should_some().sum(@loc(), t);
    first_item.parent.should_some().sum(@loc(), t).should().eq(root_id).sum(@loc(), t);
    first_item.element.name.eq("item").should().sum(@loc(), t);

    let leaf_id = index.first_child_named(first_item_id, "leaf").should_some().sum(@loc(), t);
    let leaf = index.get(leaf_id).should_some().sum(@loc(), t);
    leaf.depth.should().eq(2).sum(@loc(), t);

    let second_item_id = index.next_sibling_named(first_item_id, "item").should_some().sum(@loc(), t);
    let second_item = index.get(second_item_id).should_some().sum(@loc(), t);
    second_item.element.name.eq("item").should().sum(@loc(), t);
    index.next_sibling_named(second_item_id, "item").should_none().sum(@loc(), t);
    index.count_descendants_named(root_id, "item").should().eq(2).sum(@loc(), t);
    index.count_descendants_named(root_id, "leaf").should().eq(1).sum(@loc(), t);
}

fn check_render_round_trip() void {
    let t = test.report(io.stderr())..&;
    let page = page()..&;
    let gpa = gpa().on(page)..&;
    let source = "<?xml version=\"1.0\"?><root a=\"1\"><child/>text<![CDATA[raw]]><!--note--><?go now?></root>";
    let mut out = base.coll.string();
    defer out..&.deinit(gpa);
    let writer = out..&.writer(gpa)..&;
    xml.render_document(source, writer).should_ok().sum(@loc(), t);
    out.&.as_str().should().eq(source).sum(@loc(), t);
}

fn check_eof_split_positions() void {
    let t = test.report(io.stderr())..&;

    expect_prefix_errors("<root>", 1, 1);
    expect_prefix_errors("<root/>", 1, 1);
    expect_prefix_errors("</root>", 2, 1);
    expect_prefix_errors("<root a=\"value\">", 1, 1);
    expect_prefix_errors("<root a='value'>", 1, 1);
    expect_prefix_errors("<!--body-->", 4, 1);
    expect_prefix_errors("<![CDATA[body]]>", 9, 1);
    expect_prefix_errors("<?go body?>", 2, 1);
    expect_prefix_errors("<?xml version=\"1.0\"?>", 2, 1);
    expect_prefix_errors("<!DOCTYPE note [ <!ENTITY writer \"Donald Duck\"> ]>", 9, 1);

    let mut attr_owner = reader("<root a=\"value\" b='two'/>");
    let element = match (expect_next(attr_owner..&)) {
        .{ Empty: root } => root,
        _ => {
            t.fail_at(@loc(), "expected empty element");
        },
    };
    let mut attrs = element.attributes();
    _ = attrs..&.next().should_ok().sum(@loc(), t).should_some().sum(@loc(), t);
    _ = attrs..&.next().should_ok().sum(@loc(), t).should_some().sum(@loc(), t);
    attrs..&.next().should_ok().sum(@loc(), t).should_none().sum(@loc(), t);

    let mut bad_attr_owner = reader("<root a value>");
    let bad = match (expect_next(bad_attr_owner..&)) {
        .{ Start: root } => root,
        _ => {
            t.fail_at(@loc(), "expected start element with raw attribute bytes");
        },
    };
    let mut bad_attrs = bad.attributes();
    let attr_err = bad_attrs..&.next().should_err().sum(@loc(), t);
    attr_err.kind.should().eq(ErrorKind.InvalidAttribute).sum(@loc(), t);
}

fn main() i32 {
    check_basic_events();
    check_decode_entities();
    check_doctype_and_bom();
    check_errors_have_offsets();
    check_validation();
    check_expect_combinators();
    check_stream_combinators();
    check_namespace_views();
    check_borrowed_index();
    check_render_round_trip();
    check_eof_split_positions();
    return 0;
}
