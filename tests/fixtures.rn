use base.mem.alloc.gpa;
use base.test;
use std.io;
use sys.mem.page;
use xml.{Event, reader};

const FIXTURE =
    \\<?xml version="1.0" encoding="utf-8"?>
    \\<!DOCTYPE catalog [ <!ENTITY copy "Copyright"> ]>
    \\<catalog xmlns="urn:catalog" xmlns:x="urn:item" generated="true">
    \\  <!-- inventory fixture -->
    \\  <?fixture stage="large"?>
    \\  <x:item id="bk001" available="yes">
    \\    <title>XML Developer Guide</title>
    \\    <author>Gambardella, Matthew</author>
    \\    <summary><![CDATA[Parser coverage with <tags>, & entities, and ] ]> text.]]></summary>
    \\  </x:item>
    \\  <x:item id="bk002" available="no">
    \\    <title>Midnight Rain</title>
    \\    <author>Ralls, Kim</author>
    \\    <summary>Escaped &amp; decoded later &#x2603;</summary>
    \\  </x:item>
    \\  <group name="tools">
    \\    <tool name="reader"/>
    \\    <tool name="validator"/>
    \\    <tool name="namespace-view"/>
    \\  </group>
    \\</catalog>
;

struct Counts {
    declarations: usize = 0,
    doctypes: usize = 0,
    starts: usize = 0,
    empties: usize = 0,
    ends: usize = 0,
    text: usize = 0,
    comments: usize = 0,
    cdata: usize = 0,
    processing: usize = 0,
    items: usize = 0,
    namespace_decls: usize = 0,
};

fn count_namespace_attrs(element: xml.Element) usize {
    let t = test.report(io.stderr())..&;
    let mut total = usize.{0};
    let mut attrs = element.attributes();
    while (true) {
        let next = attrs..&.next().should_ok().sum(@loc(), t);
        let .{ Some: attr } = next else break;
        if (attr.&.is_namespace_declaration()) {
            total += 1;
        }
    }
    return total;
}

fn count_event(counts: &mut Counts, event: Event) void {
    match (event) {
        .{ Declaration: _ } => counts.declarations += 1,
        .{ Doctype: _ } => counts.doctypes += 1,
        .{ Start: element } => {
            counts.starts += 1;
            if (element.name.eq("x:item")) counts.items += 1;
            counts.namespace_decls += count_namespace_attrs(element);
        },
        .{ Empty: element } => {
            counts.empties += 1;
            counts.namespace_decls += count_namespace_attrs(element);
        },
        .{ End: _ } => counts.ends += 1,
        .{ Text: text } => if (#text.raw > 0) counts.text += 1,
        .{ Comment: _ } => counts.comments += 1,
        .{ CData: _ } => counts.cdata += 1,
        .{ ProcessingInstruction: _ } => counts.processing += 1,
    }
}

fn read_fixture_counts() Counts {
    let t = test.report(io.stderr())..&;
    let mut counts = Counts.{};
    let mut r = reader(FIXTURE);
    while (true) {
        let next = r..&.next().should_ok().sum(@loc(), t);
        let .{ Some: event } = next else break;
        count_event(counts..&, event);
    }
    return counts;
}

fn check_large_fixture_reader() void {
    let t = test.report(io.stderr())..&;
    let counts = read_fixture_counts();
    counts.declarations.should().eq(1).sum(@loc(), t);
    counts.doctypes.should().eq(1).sum(@loc(), t);
    counts.starts.should().eq(10).sum(@loc(), t);
    counts.empties.should().eq(3).sum(@loc(), t);
    counts.ends.should().eq(10).sum(@loc(), t);
    counts.comments.should().eq(1).sum(@loc(), t);
    counts.cdata.should().eq(1).sum(@loc(), t);
    counts.processing.should().eq(1).sum(@loc(), t);
    counts.items.should().eq(2).sum(@loc(), t);
    counts.namespace_decls.should().eq(2).sum(@loc(), t);
}

fn check_large_fixture_validation() void {
    let t = test.report(io.stderr())..&;
    let page = page()..&;
    let gpa = gpa().on(page)..&;
    xml.validate(FIXTURE, gpa).should_ok().sum(@loc(), t);
}

fn check_large_fixture_round_trip() void {
    let t = test.report(io.stderr())..&;
    let page = page()..&;
    let gpa = gpa().on(page)..&;
    let mut out = base.coll.string();
    defer out..&.deinit(gpa);
    let writer = out..&.writer(gpa)..&;
    xml.render_document(FIXTURE, writer).should_ok().sum(@loc(), t);
    out.&.as_str().should().eq(FIXTURE).sum(@loc(), t);
}

fn main() i32 {
    check_large_fixture_reader();
    check_large_fixture_validation();
    check_large_fixture_round_trip();
    return 0;
}
