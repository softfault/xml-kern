//! Broad XML package smoke tests.
//!
//! These tests cover tokenization, validation, decoding, namespace views,
//! indexing, ownership, rendering, and EOF error boundaries.

use base.mem.alloc.gpa;
use std.mem.Page;
use base.test.{report};
use std.io;
use xml.{
    DecodeErrorKind,
    ErrorKind,
    Event,
    ExpectErrorKind,
    ValidateErrorKind,
    reader,
};

const BASIC_EVENTS_XML =
    \\<?xml version="1.0"?>
    \\<root id="7" flag='yes'>hello &amp; <![CDATA[raw <>&]]><!--note--><?go now?>
    \\  <empty a="b"/>
    \\</root>
;

const MANY_ATTRS_DUPLICATE_XML =
    \\<root
    \\  a0="0" a1="1" a2="2" a3="3" a4="4"
    \\  a5="5" a6="6" a7="7" a8="8" a9="9"
    \\  a10="10" a11="11" a12="12" a13="13" a14="14"
    \\  a7="dup"
    \\/>
;

const NAMESPACE_INDEX_XML =
    \\<root xmlns="urn:root" xmlns:x="urn:x">
    \\  <child/>
    \\  <x:child/>
    \\  <scope xmlns="urn:inner"><child/></scope>
    \\</root>
;

const BORROWED_INDEX_XML =
    \\<root><item id="a"><leaf/></item><item id="b"/><other/></root>
;

const RENDER_ROUND_TRIP_XML =
    \\<?xml version="1.0"?><root a="1"><child/>text<![CDATA[raw]]><!--note--><?go now?></root>
;

const OWNED_DOCUMENT_XML =
    \\<root><item id="a"><leaf/></item><item id="b"/></root>
;

const FULL_DECL_XML =
    \\<?xml version="1.0" encoding="utf-8" standalone="yes"?><root/>
;

// Pulls one required event from a reader and fails the current test otherwise.
fn expect_next(r: &mut xml.Reader) Event {
    let t = report(io.stderr())..&;
    return r
        .next()
        .should_ok()
        .sum(@loc(), t)
        .should_some()
        .sum(@loc(), t);
}

// Pulls one required attribute from a cursor.
fn expect_attr(attrs: &mut xml.AttributeCursor) xml.Attribute {
    let t = report(io.stderr())..&;
    return attrs
        .next()
        .should_ok()
        .sum(@loc(), t)
        .should_some()
        .sum(@loc(), t);
}

// Asserts that an attribute cursor is exhausted.
fn expect_no_attr(attrs: &mut xml.AttributeCursor) void {
    let t = report(io.stderr())..&;
    attrs
        .next()
        .should_ok()
        .sum(@loc(), t)
        .should_none()
        .sum(@loc(), t);
}

// Pulls one required mapped element from an element adapter.
fn expect_element(elements: &mut xml.MappedReader[xml.Element]) xml.Element {
    let t = report(io.stderr())..&;
    return elements
        .next()
        .should_ok()
        .sum(@loc(), t)
        .should_some()
        .sum(@loc(), t);
}

// Asserts that an element adapter is exhausted.
fn expect_no_element(elements: &mut xml.MappedReader[xml.Element]) void {
    let t = report(io.stderr())..&;
    elements
        .next()
        .should_ok()
        .sum(@loc(), t)
        .should_none()
        .sum(@loc(), t);
}

// Pulls one required mapped name from a name adapter.
fn expect_name(names: &mut xml.MappedReader[xml.Name]) xml.Name {
    let t = report(io.stderr())..&;
    return names
        .next()
        .should_ok()
        .sum(@loc(), t)
        .should_some()
        .sum(@loc(), t);
}

// Asserts that a name adapter is exhausted.
fn expect_no_name(names: &mut xml.MappedReader[xml.Name]) void {
    let t = report(io.stderr())..&;
    names
        .next()
        .should_ok()
        .sum(@loc(), t)
        .should_none()
        .sum(@loc(), t);
}

// Checks that incomplete prefixes fail while the full source still parses.
fn expect_prefix_errors(
    source: &[u8],
    min_len: usize,
    complete_events: usize,
) void {
    let t = report(io.stderr())..&;
    for split in min_len...source.@len() {
        let mut r = reader(source.&[0...split]);
        _ = r
            ..&.next()
            .should_err()
            .sum(@loc(), t);
    }

    let mut complete = reader(source);
    for _ in 0usize...complete_events {
        _ = complete
            ..&.next()
            .should_ok()
            .sum(@loc(), t)
            .should_some()
            .sum(@loc(), t);
    }
}

// Covers the complete event mix produced by the baseline sample document.
fn check_basic_events() void {
    let t = report(io.stderr())..&;
    let mut r = reader(BASIC_EVENTS_XML);

    match (expect_next(r..&)) {
        .{ Declaration: pi } => {
            pi.target
                .eq("xml")
                .should()
                .sum(@loc(), t);
        },
        _ => t.fail_at(@loc(), "expected XML declaration"),
    }

    match (expect_next(r..&)) {
        .{ Text: text } => {
            text.raw
                .should()
                .eq("\n")
                .sum(@loc(), t);
        },
        _ => t.fail_at(@loc(), "expected declaration whitespace"),
    }

    match (expect_next(r..&)) {
        .{ Start: root } => {
            root.name
                .eq("root")
                .should()
                .sum(@loc(), t);
            let mut attrs = root.attributes();
            let id = expect_attr(attrs..&);
            let flag = expect_attr(attrs..&);
            id.name
                .eq("id")
                .should()
                .sum(@loc(), t);
            id.value.raw
                .should()
                .eq("7")
                .sum(@loc(), t);
            flag.name
                .eq("flag")
                .should()
                .sum(@loc(), t);
            flag.value.raw
                .should()
                .eq("yes")
                .sum(@loc(), t);
            expect_no_attr(attrs..&);
        },
        _ => t.fail_at(@loc(), "expected root start"),
    }

    match (expect_next(r..&)) {
        .{ Text: text } => {
            text.raw
                .should()
                .eq("hello &amp; ")
                .sum(@loc(), t);
            text
                .contains_reference()
                .should()
                .sum(@loc(), t);
        },
        _ => t.fail_at(@loc(), "expected text"),
    }
    match (expect_next(r..&)) {
        .{ CData: text } => text.raw.should().eq("raw <>&").sum(@loc(), t),
        _ => t.fail_at(@loc(), "expected cdata"),
    }
    match (expect_next(r..&)) {
        .{ Comment: text } => text.raw.should().eq("note").sum(@loc(), t),
        _ => t.fail_at(@loc(), "expected comment"),
    }
    match (expect_next(r..&)) {
        .{ ProcessingInstruction: pi } => {
            pi.target
                .eq("go")
                .should()
                .sum(@loc(), t);
            pi.body
                .should()
                .eq("now")
                .sum(@loc(), t);
        },
        _ => t.fail_at(@loc(), "expected processing instruction"),
    }
    match (expect_next(r..&)) {
        .{ Text: text } => {
            text.raw
                .should()
                .eq("\n  ")
                .sum(@loc(), t);
        },
        _ => t.fail_at(@loc(), "expected element whitespace"),
    }
    match (expect_next(r..&)) {
        .{ Empty: empty } => {
            empty.name
                .eq("empty")
                .should()
                .sum(@loc(), t);
            let mut attrs = empty.attributes();
            let attr = expect_attr(attrs..&);
            attr.name
                .eq("a")
                .should()
                .sum(@loc(), t);
            attr.value.raw
                .should()
                .eq("b")
                .sum(@loc(), t);
        },
        _ => t.fail_at(@loc(), "expected empty element"),
    }
    match (expect_next(r..&)) {
        .{ Text: text } => {
            text.raw
                .should()
                .eq("\n")
                .sum(@loc(), t);
        },
        _ => t.fail_at(@loc(), "expected trailing element whitespace"),
    }
    match (expect_next(r..&)) {
        .{ End: name } => name.eq("root").should().sum(@loc(), t),
        _ => t.fail_at(@loc(), "expected root end"),
    }
    r
        ..&.next()
        .should_ok()
        .sum(@loc(), t)
        .should_none()
        .sum(@loc(), t);
    r.&.is_done()
        .should()
        .sum(@loc(), t);
}

// Verifies predefined entities, numeric references, and owned decode cloning.
fn check_decode_entities() void {
    let t = report(io.stderr())..&;
    let text = xml.EncodedText.{ raw: "a&amp;b&lt;c&gt;&apos;&quot;&#65;&#x1F600;" };
    text
        .decoded_size()
        .should_ok()
        .sum(@loc(), t)
        .should()
        .eq(13)
        .sum(@loc(), t);

    let mut out: [32]u8 = undef;
    let written = text
        .write_decoded(out..&[0...32])
        .should_ok()
        .sum(@loc(), t);
    let expected = [13]u8.{
        b'a', b'&', b'b', b'<', b'c', b'>', b'\'', b'"', b'A',
        0xF0, 0x9F, 0x98, 0x80,
    };
    out.&[0...written]
        .should()
        .eq(expected.&[0...13])
        .sum(@loc(), t);

    let page = Page.{}..&;
    let gpa = gpa().on(page)..&;
    let mut cloned = text
        .clone_decoded(gpa)
        .should_ok()
        .sum(@loc(), t);
    defer cloned..&.deinit(gpa);
    cloned.&.as_str()
        .should()
        .eq(out.&[0...written])
        .sum(@loc(), t);
}

// Verifies BOM skipping and doctype internal-subset scanning.
fn check_doctype_and_bom() void {
    let t = report(io.stderr())..&;
    let source = [60]u8.{
        0xEF, 0xBB, 0xBF,
        b'<', b'!', b'D', b'O', b'C', b'T', b'Y', b'P', b'E', b' ',
        b'n', b'o', b't', b'e', b' ', b'[', b' ', b'<', b'!', b'E',
        b'N', b'T', b'I', b'T', b'Y', b' ', b'w', b'r', b'i', b't',
        b'e', b'r', b' ', b'"', b'D', b'o', b'n', b'a', b'l', b'd',
        b' ', b'D', b'u', b'c', b'k', b'"', b'>', b' ', b']', b'>',
        b'<', b'n', b'o', b't', b'e', b'/', b'>',
    };
    let mut r = reader(source.&[0...60]);
    match (expect_next(r..&)) {
        .{ Doctype: text } => text.raw
            .should()
            .eq(" note [ <!ENTITY writer \"Donald Duck\"> ]")
            .sum(@loc(), t),
        _ => t.fail_at(@loc(), "expected doctype"),
    }
    match (expect_next(r..&)) {
        .{ Empty: note } => note.name.eq("note").should().sum(@loc(), t),
        _ => t.fail_at(@loc(), "expected empty note"),
    }
    r
        ..&.next()
        .should_ok()
        .sum(@loc(), t)
        .should_none()
        .sum(@loc(), t);
}

// Verifies malformed input reports stable error categories and offsets.
fn check_errors_have_offsets() void {
    let t = report(io.stderr())..&;
    let mut full_decl = reader(FULL_DECL_XML);
    match (expect_next(full_decl..&)) {
        .{ Declaration: pi } => {
            pi.target
                .eq("xml")
                .should()
                .sum(@loc(), t);
            pi.body
                .should()
                .eq("version=\"1.0\" encoding=\"utf-8\" standalone=\"yes\"")
                .sum(@loc(), t);
        },
        _ => t.fail_at(@loc(), "expected full XML declaration"),
    }

    let mut r = reader("<root><!--oops");
    match (expect_next(r..&)) {
        .{ Start: root } => root.name.eq("root").should().sum(@loc(), t),
        _ => t.fail_at(@loc(), "expected root"),
    }
    let err = r
        ..&.next()
        .should_err()
        .sum(@loc(), t);
    err.kind
        .should()
        .eq(ErrorKind.UnterminatedComment)
        .sum(@loc(), t);
    err.offset
        .should()
        .eq(6)
        .sum(@loc(), t);

    let bad = xml.EncodedText.{ raw: "&wat;" }
        .decoded_size()
        .should_err()
        .sum(@loc(), t);
    bad.kind
        .should()
        .eq(DecodeErrorKind.UnknownEntity)
        .sum(@loc(), t);
    bad.offset
        .should()
        .eq(0)
        .sum(@loc(), t);

    let loc = "a\nbc".location(3);
    loc.line
        .should()
        .eq(2)
        .sum(@loc(), t);
    loc.column
        .should()
        .eq(2)
        .sum(@loc(), t);

    let mut bad_comment = reader("<root><!--bad--body--></root>");
    match (expect_next(bad_comment..&)) {
        .{ Start: root } => root.name.eq("root").should().sum(@loc(), t),
        _ => t.fail_at(@loc(), "expected root"),
    }
    let comment_err = bad_comment
        ..&.next()
        .should_err()
        .sum(@loc(), t);
    comment_err.kind
        .should()
        .eq(ErrorKind.InvalidComment)
        .sum(@loc(), t);
    comment_err.offset
        .should()
        .eq(13)
        .sum(@loc(), t);

    let mut bad_text = reader("<root>bad ]]></root>");
    match (expect_next(bad_text..&)) {
        .{ Start: root } => root.name.eq("root").should().sum(@loc(), t),
        _ => t.fail_at(@loc(), "expected root"),
    }
    let text_err = bad_text
        ..&.next()
        .should_err()
        .sum(@loc(), t);
    text_err.kind
        .should()
        .eq(ErrorKind.InvalidCharacterData)
        .sum(@loc(), t);

    let mut late_decl = reader("<root><?xml version=\"1.0\"?></root>");
    match (expect_next(late_decl..&)) {
        .{ Start: root } => root.name.eq("root").should().sum(@loc(), t),
        _ => t.fail_at(@loc(), "expected root"),
    }
    let decl_err = late_decl
        ..&.next()
        .should_err()
        .sum(@loc(), t);
    decl_err.kind
        .should()
        .eq(ErrorKind.InvalidDeclaration)
        .sum(@loc(), t);

    let mut bad_decl = reader("<?xml encoding=\"utf-8\"?><root/>");
    let bad_decl_err = bad_decl
        ..&.next()
        .should_err()
        .sum(@loc(), t);
    bad_decl_err.kind
        .should()
        .eq(ErrorKind.InvalidDeclaration)
        .sum(@loc(), t);

    let mut duplicate_decl_attr = reader("<?xml version=\"1.0\" version=\"1.1\"?><root/>");
    let duplicate_decl_attr_err = duplicate_decl_attr
        ..&.next()
        .should_err()
        .sum(@loc(), t);
    duplicate_decl_attr_err.kind
        .should()
        .eq(ErrorKind.InvalidDeclaration)
        .sum(@loc(), t);

    let mut out_of_order_decl = reader(
        "<?xml version=\"1.0\" standalone=\"yes\" encoding=\"utf-8\"?><root/>"
    );
    let out_of_order_decl_err = out_of_order_decl
        ..&.next()
        .should_err()
        .sum(@loc(), t);
    out_of_order_decl_err.kind
        .should()
        .eq(ErrorKind.InvalidDeclaration)
        .sum(@loc(), t);

    let mut bad_version_decl = reader("<?xml version=\"2.0\"?><root/>");
    let bad_version_decl_err = bad_version_decl
        ..&.next()
        .should_err()
        .sum(@loc(), t);
    bad_version_decl_err.kind
        .should()
        .eq(ErrorKind.InvalidDeclaration)
        .sum(@loc(), t);

    let mut bad_encoding_decl = reader("<?xml version=\"1.0\" encoding=\"1bad\"?><root/>");
    let bad_encoding_decl_err = bad_encoding_decl
        ..&.next()
        .should_err()
        .sum(@loc(), t);
    bad_encoding_decl_err.kind
        .should()
        .eq(ErrorKind.InvalidDeclaration)
        .sum(@loc(), t);

    let mut bad_standalone_decl = reader("<?xml version=\"1.0\" standalone=\"maybe\"?><root/>");
    let bad_standalone_decl_err = bad_standalone_decl
        ..&.next()
        .should_err()
        .sum(@loc(), t);
    bad_standalone_decl_err.kind
        .should()
        .eq(ErrorKind.InvalidDeclaration)
        .sum(@loc(), t);

    let mut invalid_name = reader("<1root/>");
    let invalid_name_err = invalid_name
        ..&.next()
        .should_err()
        .sum(@loc(), t);
    invalid_name_err.kind
        .should()
        .eq(ErrorKind.InvalidName)
        .sum(@loc(), t);

    let invalid_utf8_source = [3]u8.{ b'<', 0xC0, b'>' };
    let mut invalid_utf8 = reader(invalid_utf8_source.&[0...3]);
    let invalid_utf8_err = invalid_utf8
        ..&.next()
        .should_err()
        .sum(@loc(), t);
    invalid_utf8_err.kind
        .should()
        .eq(ErrorKind.InvalidName)
        .sum(@loc(), t);

    let mut unicode_name = reader("<é/>");
    match (expect_next(unicode_name..&)) {
        .{ Empty: element } => element.name.raw
            .should()
            .eq("é")
            .sum(@loc(), t),
        _ => t.fail_at(@loc(), "expected unicode empty element"),
    }
}

// Verifies document-level validation rules above tokenization.
fn check_validation() void {
    let t = report(io.stderr())..&;
    let page = Page.{}..&;
    let gpa = gpa().on(page)..&;

    "<root><child/><child>text</child></root>".validate(gpa)
        .should_ok()
        .sum(@loc(), t);

    let mismatch = "<root><a></root>".validate(gpa)
        .should_err()
        .sum(@loc(), t);
    match (mismatch.kind) {
        .MismatchedEnd => {},
        _ => t.fail_at(@loc(), "expected mismatched end"),
    }

    let multiple = "<a/><b/>".validate(gpa)
        .should_err()
        .sum(@loc(), t);
    match (multiple.kind) {
        .MultipleRoots => {},
        _ => t.fail_at(@loc(), "expected multiple roots"),
    }

    let missing = "   <!-- only comment -->".validate(gpa)
        .should_err()
        .sum(@loc(), t);
    match (missing.kind) {
        .MissingRoot => {},
        _ => t.fail_at(@loc(), "expected missing root"),
    }

    let parse = "<root><!-- bad".validate(gpa)
        .should_err()
        .sum(@loc(), t);
    match (parse.kind) {
        .{ Parse: kind } => kind.should().eq(ErrorKind.UnterminatedComment).sum(@loc(), t),
        _ => t.fail_at(@loc(), "expected parse error"),
    }

    let duplicate = "<root a=\"1\" a=\"2\"/>".validate(gpa)
        .should_err()
        .sum(@loc(), t);
    match (duplicate.kind) {
        .DuplicateAttribute => {},
        _ => t.fail_at(@loc(), "expected duplicate attribute"),
    }

    let nested_duplicate = "<root><child id=\"1\" id=\"2\"/></root>".validate(gpa)
        .should_err()
        .sum(@loc(), t);
    match (nested_duplicate.kind) {
        .DuplicateAttribute => {},
        _ => t.fail_at(@loc(), "expected nested duplicate attribute"),
    }

    let many_attrs = MANY_ATTRS_DUPLICATE_XML.validate(gpa)
        .should_err()
        .sum(@loc(), t);
    match (many_attrs.kind) {
        .DuplicateAttribute => {},
        _ => t.fail_at(@loc(), "expected duplicate among many attributes"),
    }
}

// Verifies structured reader helpers skip ignorable events and detect mismatch.
fn check_expect_combinators() void {
    let t = report(io.stderr())..&;
    let mut r = reader("<!--meta--><root><leaf/></root>");
    let root = r
        ..&.expect_start("root")
        .should_ok()
        .sum(@loc(), t);
    root.name
        .eq("root")
        .should()
        .sum(@loc(), t);
    let leaf = r
        ..&.expect_empty("leaf")
        .should_ok()
        .sum(@loc(), t);
    leaf.name
        .eq("leaf")
        .should()
        .sum(@loc(), t);
    r
        ..&.expect_end("root")
        .should_ok()
        .sum(@loc(), t)
        .eq("root")
        .should()
        .sum(@loc(), t);
    r
        ..&.next_significant()
        .should_ok()
        .sum(@loc(), t)
        .should_none()
        .sum(@loc(), t);

    let mut wrong = reader("<root/>");
    let err = wrong
        ..&.expect_start("root")
        .should_err()
        .sum(@loc(), t);
    match (err.kind) {
        .UnexpectedEvent => {},
        _ => t.fail_at(@loc(), "expected unexpected event"),
    }

    let mut mismatch = reader("<other></other>");
    let mismatch_err = mismatch
        ..&.expect_start("root")
        .should_err()
        .sum(@loc(), t);
    match (mismatch_err.kind) {
        .NameMismatch => {},
        _ => t.fail_at(@loc(), "expected name mismatch"),
    }
}

// Verifies stream traits, filters, and mapping adapters compose correctly.
fn check_stream_combinators() void {
    let t = report(io.stderr())..&;

    let mut counted_reader = reader("<root><child/>text</root>");
    let mut stats = xml.SinkStats.{};
    let stream = (counted_reader..& as &mut xml.EventStream);
    let sink = (stats..& as &mut xml.EventSink);
    stream.drain_into(sink)
        .should_ok()
        .sum(@loc(), t)
        .should()
        .eq(4usize)
        .sum(@loc(), t);
    stats.events
        .should()
        .eq(4usize)
        .sum(@loc(), t);
    stats.starts
        .should()
        .eq(1usize)
        .sum(@loc(), t);
    stats.empties
        .should()
        .eq(1usize)
        .sum(@loc(), t);
    stats.ends
        .should()
        .eq(1usize)
        .sum(@loc(), t);
    stats.text
        .should()
        .eq(1usize)
        .sum(@loc(), t);

    let mut noisy = reader("<!--meta--> \n <root><?go?></root>");
    let mut significant = noisy..&.filter_significant();
    let significant_start = significant
        ..&.next()
        .should_ok()
        .sum(@loc(), t)
        .should_some()
        .sum(@loc(), t);
    match (significant_start) {
        .{ Start: root } => root.name.eq("root").should().sum(@loc(), t),
        _ => t.fail_at(@loc(), "expected significant start"),
    }
    let significant_end = significant
        ..&.next()
        .should_ok()
        .sum(@loc(), t)
        .should_some()
        .sum(@loc(), t);
    match (significant_end) {
        .{ End: name } => name.eq("root").should().sum(@loc(), t),
        _ => t.fail_at(@loc(), "expected significant end"),
    }
    significant
        ..&.next()
        .should_ok()
        .sum(@loc(), t)
        .should_none()
        .sum(@loc(), t);

    let mut source = reader("<root><leaf/>tail</root>");
    let mut elements = source..&.elements();
    expect_element(elements..&).name
        .eq("root")
        .should()
        .sum(@loc(), t);
    expect_element(elements..&).name
        .eq("leaf")
        .should()
        .sum(@loc(), t);
    expect_no_element(elements..&);

    let mut named_source = reader("<root><leaf/></root>");
    let mut names = named_source..&.names();
    expect_name(names..&)
        .eq("root")
        .should()
        .sum(@loc(), t);
    expect_name(names..&)
        .eq("leaf")
        .should()
        .sum(@loc(), t);
    expect_name(names..&)
        .eq("root")
        .should()
        .sum(@loc(), t);
    expect_no_name(names..&);
}

// Verifies lexical namespace helpers on element and attribute names.
fn check_namespace_views() void {
    let t = report(io.stderr())..&;
    let mut r = reader("<x:root xmlns=\"urn:default\" xmlns:x=\"urn:x\" x:id=\"7\" plain=\"v\"/>");
    match (expect_next(r..&)) {
        .{ Empty: root } => {
            let root_name = root.&.qualified_name();
            root_name.prefix
                .should_some()
                .sum(@loc(), t)
                .should()
                .eq("x")
                .sum(@loc(), t);
            root_name.local
                .should()
                .eq("root")
                .sum(@loc(), t);

            let mut attrs = root.attributes();
            let default_ns = expect_attr(attrs..&);
            match (default_ns.&.namespace_declaration().should_some().sum(@loc(), t)) {
                .{ Default: uri } => uri.raw.should().eq("urn:default").sum(@loc(), t),
                _ => t.fail_at(@loc(), "expected default namespace"),
            }

            let prefixed_ns = expect_attr(attrs..&);
            match (prefixed_ns.&.namespace_declaration().should_some().sum(@loc(), t)) {
                .{ Prefixed: binding } => {
                    binding.prefix
                        .should()
                        .eq("x")
                        .sum(@loc(), t);
                    binding.uri.raw
                        .should()
                        .eq("urn:x")
                        .sum(@loc(), t);
                },
                _ => t.fail_at(@loc(), "expected prefixed namespace"),
            }

            let id = expect_attr(attrs..&);
            (!id.&.is_namespace_declaration()).should().sum(@loc(), t);
            let id_name = id.&.qualified_name();
            id_name.prefix
                .should_some()
                .sum(@loc(), t)
                .should()
                .eq("x")
                .sum(@loc(), t);
            id_name.local
                .should()
                .eq("id")
                .sum(@loc(), t);

            let plain = expect_attr(attrs..&);
            let plain_name = plain.&.qualified_name();
            plain_name.prefix
                .should_none()
                .sum(@loc(), t);
            plain.name.&.local()
                .should()
                .eq("plain")
                .sum(@loc(), t);
        },
        _ => t.fail_at(@loc(), "expected namespaced empty element"),
    }
}

// Verifies namespace resolution over the borrowed document index.
fn check_namespace_index_queries() void {
    let t = report(io.stderr())..&;
    let page = Page.{}..&;
    let gpa = gpa().on(page)..&;
    let index = NAMESPACE_INDEX_XML.build_index(gpa)
        .should_ok()
        .sum(@loc(), t)..&;
    defer index.deinit(gpa);

    let root_id = index
        .root()
        .should_some()
        .sum(@loc(), t);
    let root_name = index
        .resolved_name(root_id)
        .should_some()
        .sum(@loc(), t);
    let root_uri = root_name.uri.should_some().sum(@loc(), t);
    root_uri.raw
        .should()
        .eq("urn:root")
        .sum(@loc(), t);
    root_name.local
        .should()
        .eq("root")
        .sum(@loc(), t);

    let default_child = index
        .first_child_ns(root_id, "urn:root", "child")
        .should_some()
        .sum(@loc(), t);
    let default_child_node = index
        .get(default_child)
        .should_some()
        .sum(@loc(), t);
    default_child_node.element.name
        .eq("child")
        .should()
        .sum(@loc(), t);

    let prefixed_child = index
        .first_child_ns(root_id, "urn:x", "child")
        .should_some()
        .sum(@loc(), t);
    let prefixed_child_node = index
        .get(prefixed_child)
        .should_some()
        .sum(@loc(), t);
    prefixed_child_node.element.name
        .eq("x:child")
        .should()
        .sum(@loc(), t);

    let scope_id = index
        .first_child_named(root_id, "scope")
        .should_some()
        .sum(@loc(), t);
    let inner_child = index
        .first_child_ns(scope_id, "urn:inner", "child")
        .should_some()
        .sum(@loc(), t);
    let inner_name = index
        .resolved_name(inner_child)
        .should_some()
        .sum(@loc(), t);
    let inner_uri = inner_name.uri.should_some().sum(@loc(), t);
    inner_uri.raw
        .should()
        .eq("urn:inner")
        .sum(@loc(), t);
}

// Verifies borrowed index topology and name-based navigation.
fn check_borrowed_index() void {
    let t = report(io.stderr())..&;
    let page = Page.{}..&;
    let gpa = gpa().on(page)..&;
    let index = BORROWED_INDEX_XML.build_index(gpa)
        .should_ok()
        .sum(@loc(), t)..&;
    defer index.deinit(gpa);

    index
        .len()
        .should()
        .eq(5)
        .sum(@loc(), t);
    let root_id = index
        .root()
        .should_some()
        .sum(@loc(), t);
    let root = index
        .get(root_id)
        .should_some()
        .sum(@loc(), t);
    root.element.name
        .eq("root")
        .should()
        .sum(@loc(), t);
    root.depth
        .should()
        .eq(0)
        .sum(@loc(), t);

    let first_item_id = index
        .first_child_named(root_id, "item")
        .should_some()
        .sum(@loc(), t);
    let first_item = index
        .get(first_item_id)
        .should_some()
        .sum(@loc(), t);
    first_item.parent
        .should_some()
        .sum(@loc(), t)
        .should()
        .eq(root_id)
        .sum(@loc(), t);
    first_item.element.name
        .eq("item")
        .should()
        .sum(@loc(), t);

    let leaf_id = index
        .first_child_named(first_item_id, "leaf")
        .should_some()
        .sum(@loc(), t);
    let leaf = index
        .get(leaf_id)
        .should_some()
        .sum(@loc(), t);
    leaf.depth
        .should()
        .eq(2)
        .sum(@loc(), t);

    let second_item_id = index
        .next_sibling_named(first_item_id, "item")
        .should_some()
        .sum(@loc(), t);
    let second_item = index
        .get(second_item_id)
        .should_some()
        .sum(@loc(), t);
    second_item.element.name
        .eq("item")
        .should()
        .sum(@loc(), t);
    index
        .next_sibling_named(second_item_id, "item")
        .should_none()
        .sum(@loc(), t);
    index
        .count_descendants_named(root_id, "item")
        .should()
        .eq(2)
        .sum(@loc(), t);
    index
        .count_descendants_named(root_id, "leaf")
        .should()
        .eq(1usize)
        .sum(@loc(), t);
}

// Verifies event rendering preserves the original source bytes.
fn check_render_round_trip() void {
    let t = report(io.stderr())..&;
    let page = Page.{}..&;
    let gpa = gpa().on(page)..&;
    let source = RENDER_ROUND_TRIP_XML;
    let mut out = base.coll.string();
    defer out..&.deinit(gpa);
    let writer = out..&.writer(gpa)..&;
    source.render_to(writer)
        .should_ok()
        .sum(@loc(), t);
    out.&.as_str()
        .should()
        .eq(source)
        .sum(@loc(), t);
}

// Verifies owned documents clone element slices and preserve topology.
fn check_owned_document_tree() void {
    let t = report(io.stderr())..&;
    let page = Page.{}..&;
    let gpa = gpa().on(page)..&;
    let doc = OWNED_DOCUMENT_XML.clone_owned_document(gpa)
        .should_ok()
        .sum(@loc(), t)..&;
    defer doc.deinit(gpa);

    doc
        .len()
        .should()
        .eq(4usize)
        .sum(@loc(), t);
    let root_id = doc
        .root()
        .should_some()
        .sum(@loc(), t);
    let root = doc
        .get(root_id)
        .should_some()
        .sum(@loc(), t);
    root.element.name.&.as_str()
        .should()
        .eq("root")
        .sum(@loc(), t);
    let item_id = doc
        .first_child_named(root_id, "item")
        .should_some()
        .sum(@loc(), t);
    let item = doc
        .get(item_id)
        .should_some()
        .sum(@loc(), t);
    item.element.raw.&.as_str()
        .should()
        .eq("<item id=\"a\">")
        .sum(@loc(), t);
    let leaf_id = doc
        .first_child_named(item_id, "leaf")
        .should_some()
        .sum(@loc(), t);
    let leaf = doc
        .get(leaf_id)
        .should_some()
        .sum(@loc(), t);
    leaf.element.name.&.as_str()
        .should()
        .eq("leaf")
        .sum(@loc(), t);
}

// Verifies EOF handling across partial XML prefixes and attribute cursors.
fn check_eof_split_positions() void {
    let t = report(io.stderr())..&;

    expect_prefix_errors("<root>", 1, 1);
    expect_prefix_errors("<root/>", 1, 1);
    expect_prefix_errors("</root>", 2, 1);
    expect_prefix_errors("<root a=\"value\">", 1, 1);
    expect_prefix_errors("<root a='value'>", 1, 1);
    expect_prefix_errors("<!--body-->", 4, 1);
    expect_prefix_errors("<![CDATA[body]]>", 9, 1);
    expect_prefix_errors("<?go body?>", 2, 1);
    expect_prefix_errors("<?xml version=\"1.0\"?>", 2, 1);
    expect_prefix_errors("<!DOCTYPE note [ <!ENTITY writer \"Donald Duck\"> ]>", 9, 1);

    let mut attr_owner = reader("<root a=\"value\" b='two'/>");
    let element = match (expect_next(attr_owner..&)) {
        .{ Empty: root } => root,
        _ => {
            t.fail_at(@loc(), "expected empty element");
        },
    };
    let mut attrs = element.attributes();
    _ = expect_attr(attrs..&);
    _ = expect_attr(attrs..&);
    expect_no_attr(attrs..&);

    let mut bad_attr_owner = reader("<root a value>");
    let bad = match (expect_next(bad_attr_owner..&)) {
        .{ Start: root } => root,
        _ => {
            t.fail_at(@loc(), "expected start element with raw attribute bytes");
        },
    };
    let mut bad_attrs = bad.attributes();
    let attr_err = bad_attrs
        ..&.next()
        .should_err()
        .sum(@loc(), t);
    attr_err.kind
        .should()
        .eq(ErrorKind.InvalidAttribute)
        .sum(@loc(), t);
}

// Test entry point for the broad smoke suite.
#[test]
fn smoke() i32 {
    check_basic_events();
    check_decode_entities();
    check_doctype_and_bom();
    check_errors_have_offsets();
    check_validation();
    check_expect_combinators();
    check_stream_combinators();
    check_namespace_views();
    check_namespace_index_queries();
    check_borrowed_index();
    check_render_round_trip();
    check_owned_document_tree();
    check_eof_split_positions();
    return 0;
}
